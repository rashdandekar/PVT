<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gas Properties Calculator</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        form { max-width: 400px; }
        label { display: block; margin-top: 10px; }
        input { width: 100%; padding: 8px; margin-top: 5px; }
        button { margin-top: 20px; padding: 10px 20px; background-color: #007bff; color: white; border: none; cursor: pointer; }
        button:hover { background-color: #0056b3; }
    </style>
</head>
<body>
    <h1>Gas Properties Calculator</h1>
    <form action="/calculate" method="POST">
        <label for="spgr">Specific Gravity:</label>
        <input type="number" step="0.01" id="spgr" name="spgr" required>

        <label for="h2s">H2S Percentage:</label>
        <input type="number" step="0.0001" id="h2s" name="h2s" required>

        <label for="co2">CO2 Percentage:</label>
        <input type="number" step="0.0001" id="co2" name="co2" required>

        <label for="n2">N2 Percentage:</label>
        <input type="number" step="0.0001" id="n2" name="n2" required>

        <label for="pressure">Pressure (psia):</label>
        <input type="number" step="0.01" id="pressure" name="pressure" required>

        <label for="temperature">Temperature (°F):</label>
        <input type="number" step="0.01" id="temperature" name="temperature" required>

        <button type="submit">Calculate Properties</button>
    </form>
</body>
</html>